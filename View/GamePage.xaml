<UserControl x:Class="NFL_Quiz.GamePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:NFL_Quiz"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="100" />
            <RowDefinition Height="120" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="NFL Quiz" FontSize="56" HorizontalAlignment="Center" />

        <StackPanel Grid.Row="1" Grid.Column="1" VerticalAlignment="Top">
            <Grid HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchBox"
                         Grid.Row="0"
                         Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         MinWidth="200"
                         Padding="15"/>

                <Button Grid.Row="0"
                        Grid.Column="1"
                        IsDefault="True"
                        Content="Submit"
                        Command="{Binding SubmitCommand}"
                        Height="40"
                        MinWidth="60"
                        VerticalAlignment="Center"
                        Margin="5"/>

                <ListBox Grid.Row="1"
                         Grid.Column="0"
                         ItemsSource="{Binding Suggestions}" 
                         SelectedItem="{Binding SelectedSuggestion, Mode=TwoWay}"
                         Width="{Binding ActualWidth, ElementName=SearchBox}"
                         MaxHeight="70"
                         Margin="0,2,0,0"
                         Visibility="{Binding HasItems, RelativeSource={RelativeSource Self}, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </StackPanel>

        <ItemsControl ItemsSource="{Binding Guesses}" Grid.Row="2">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Player.Name}" Background="{Binding nameBrush}" Grid.Column="0" VerticalAlignment="Center" Padding="5"/>
                        <TextBlock Text="{Binding trikotDisplay}" Background="{Binding trikotBrush}" Grid.Column="1" VerticalAlignment="Center" Padding="5"/>
                        <TextBlock Text="{Binding Player.Position}" Background="{Binding positionBrush}" Grid.Column="2" VerticalAlignment="Center" Padding="5"/>
                        <TextBlock Text="{Binding Player.Team}" Background="{Binding teamBrush}" Grid.Column="3" VerticalAlignment="Center" Padding="5"/>
                        <TextBlock Text="{Binding Player.Conference}" Background="{Binding conferenceBrush}" Grid.Column="4" VerticalAlignment="Center" Padding="5"/>
                        <TextBlock Text="{Binding Player.Division}" Background="{Binding divisionBrush}" Grid.Column="5" VerticalAlignment="Center" Padding="5"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>