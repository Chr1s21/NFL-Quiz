<UserControl x:Class="NFL_Quiz.GamePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:vm="clr-namespace:NFL_Quiz.ViewModel"
      xmlns:local="clr-namespace:NFL_Quiz"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.DataContext>
        <vm:GamePageViewModel/>
    </UserControl.DataContext>
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="100" />
            <RowDefinition Height="150" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="NFL Quiz" FontSize="56" HorizontalAlignment="Center" />

        <StackPanel Grid.Row="1" Grid.Column="1" VerticalAlignment="Top">
            <Grid HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchBox"
                         Grid.Row="0"
                         Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         MinWidth="200"
                         Padding="15"/>

                <Button Grid.Row="0"
                        Grid.Column="1"
                        IsDefault="True"
                        Content="Submit"
                        Command="{Binding SubmitCommand}"
                        Style="{StaticResource DesignedButton}"
                        Height="60"
                        MinWidth="100"
                        Margin="5"/>

                <ListBox Grid.Row="1"
                         Grid.Column="0"
                         ItemsSource="{Binding Suggestions}" 
                         SelectedItem="{Binding SelectedSuggestion, Mode=TwoWay}"
                         Width="{Binding ActualWidth, ElementName=SearchBox}"
                         MaxHeight="70"
                         IsTabStop="True"
                         KeyboardNavigation.TabNavigation="Cycle"
                         Margin="0,2,0,0"
                         Visibility="{Binding HasItems, RelativeSource={RelativeSource Self}, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </StackPanel>

        <ItemsControl ItemsSource="{Binding Guesses}" Grid.Row="2">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="4" Padding="2" Background="Transparent">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="8"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                                <Style x:Key="FieldBorder" TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                    <Setter Property="Margin" Value="2"/>
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.2"/>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Grid.Resources>

                            <Border Style="{StaticResource FieldBorder}" Background="{Binding nameBrush}" Grid.Column="0">
                                <TextBlock Text="{Binding Player.Name}" TextWrapping="Wrap"/>
                            </Border>
                            <Border Style="{StaticResource FieldBorder}" Background="{Binding trikotBrush}" Grid.Column="1">
                                <TextBlock Text="{Binding trikotDisplay}"/>
                            </Border>
                            <Border Style="{StaticResource FieldBorder}" Background="{Binding positionBrush}" Grid.Column="2">
                                <TextBlock Text="{Binding Player.Position}"/>
                            </Border>
                            <Border Style="{StaticResource FieldBorder}" Background="{Binding teamBrush}" Grid.Column="3">
                                <TextBlock Text="{Binding Player.Team}" TextWrapping="Wrap"/>
                            </Border>
                            <Border Style="{StaticResource FieldBorder}" Background="{Binding conferenceBrush}" Grid.Column="4">
                                <TextBlock Text="{Binding Player.Conference}"/>
                            </Border>
                            <Border Style="{StaticResource FieldBorder}" Background="{Binding divisionBrush}" Grid.Column="5">
                                <TextBlock Text="{Binding Player.Division}"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>