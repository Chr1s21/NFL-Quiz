<Page x:Class="NFL_Quiz.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:NFL_Quiz"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SettingsPage">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0">
            <Button Content="Add Player" Click="AddPlayer_Click" HorizontalAlignment="Left" Margin="10" Width="100"/>
            <Button Content="Delete Player" Click="Delete_Click" HorizontalAlignment="Left" Margin="10" Width="100"/>
            <Button Content="Save List" Click="Save_Click" HorizontalAlignment="Left" Margin="10" Width="100"/>
        </StackPanel>

        <DataGrid Grid.Row="1" x:Name="PlayerGrid" 
                  AutoGenerateColumns="True" 
                  Margin="10" 
                  AlternatingRowBackground="GhostWhite"
                  CanUserAddRows="False">
        </DataGrid>
    </Grid>
</Page>