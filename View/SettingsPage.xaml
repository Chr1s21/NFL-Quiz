<UserControl x:Class="NFL_Quiz.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:NFL_Quiz"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0">
            <Button Content="Add Player" Command="{Binding AddPlayerCommand}" HorizontalAlignment="Left" Margin="10" Width="100"/>
            <Button Content="Delete Player" Command="{Binding DeletePlayerCommand}" CommandParameter="{Binding SelectedItem, ElementName=PlayerGrid}" HorizontalAlignment="Left" Margin="10" Width="100"/>
            <Button Content="Save List" Command="{Binding SaveCommand}" HorizontalAlignment="Left" Margin="10" Width="100"/>
        </StackPanel>

        <DataGrid Grid.Row="1" x:Name="PlayerGrid" 
                  ItemsSource="{Binding Players}"
                  AutoGenerateColumns="True" 
                  Margin="10" 
                  AlternatingRowBackground="{StaticResource BackgroundBrush}"
                  CanUserAddRows="False"
                  ColumnWidth="*">
        </DataGrid>
    </Grid>
</UserControl>